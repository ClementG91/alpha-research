  {
    "name": "compose_strategy",
    "title": null,
    "description": "Build a StrategyDef from natural DSL expressions - the easy way to author on this server, instead of writing StrategyDef JSON by hand. Pass `signals` as {name: expression} and `size` as one expression, e.g. signals={'fast': 'ema(close, 5)', 'slow': 'ema(close, 20)'}, size='when(crossover(fast, slow), 1.0, 0.0)'. A signal may reference an earlier one by name. Indicators are unprefixed (ema, rsi, sma, atr, crossover, crossunder, highest, lowest, when); combine conditions with & and |. Position size is a FRACTION: 1.0 = fully long, 0.0 = flat, -1.0 = short. To HOLD the current position when no condition fires, write hold() (or omit when's 3rd argument) - NOT -1, which opens a short. Returns strategy_json ready for run_backtest. Python is never executed - only these expressions are compiled.",
    "inputSchema": {
      "properties": {
        "signals": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Signals",
          "type": "object"
        },
        "size": {
          "title": "Size",
          "type": "string"
        },
        "name": {
          "default": "strategy",
          "title": "Name",
          "type": "string"
        },
        "parameters": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parameters"
        }
      },
      "required": [
        "signals",
        "size"
      ],
      "title": "compose_strategyArguments",
      "type": "object"
    },
    "outputSchema": {
      "additionalProperties": true,
      "title": "compose_strategyDictOutput",
      "type": "object"
    },
    "icons": null,
    "annotations": {
      "title": null,
